# Django
# DEBUG now defaults to False (production-safe). Set it True for local dev.
# In production (DEBUG=False) the app REFUSES to start unless SECRET_KEY and
# FIELD_ENCRYPTION_KEY below are set to real (non-default) values.
DEBUG=True
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-generate-with-django-shell

# Field-level encryption (AES-256 via Fernet)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production. Losing this key means encrypted credential data is unrecoverable.
FIELD_ENCRYPTION_KEY=generate-and-set-this-before-any-credentials-are-stored
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — SQLite by default (what production runs; nothing to install).
# For PostgreSQL instead, set DB_ENGINE=postgresql and fill in the vars below.
# (DB_ENGINE takes the short token 'sqlite3' or 'postgresql', not a dotted path.)
DB_ENGINE=sqlite3
# DB_NAME=murphys_bench       # PostgreSQL only
# DB_USER=postgres            # PostgreSQL only
# DB_PASSWORD=your-password-here
# DB_HOST=localhost
# DB_PORT=5432

# Email (optional, for Phase 2)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Application
COMPANY_NAME=Your Shop Name
TIMEZONE=America/Los_Angeles
